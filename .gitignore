*.pkl
*.h5
*.model

# Data Files
# Keep the folder structure, but ignore the actual CSVs if they are large
data/*.csv
data/*.zip

# Operating System Files
.DS_Store
Thumbs.db

# Streamlit logs/config
.streamlit/